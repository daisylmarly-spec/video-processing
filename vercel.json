{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/xf-asr/[...path].ts": { "maxDuration": 60, "regions": ["hnd1"] },
    "api/xf-mt/[...path].ts":  { "maxDuration": 60, "regions": ["hnd1"] }
  },
  "rewrites": [
    { "source": "/api/xf-asr/:path*", "destination": "/api/xf-asr/[...path]" },
    { "source": "/api/xf-mt/:path*",  "destination": "/api/xf-mt/[...path]"  },
    { "source": "/(.*)",              "destination": "/index.html"             }
  ]
}
